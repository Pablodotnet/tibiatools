rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tierProjects/{projectId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if resource.data.ownerUid == request.auth.uid
        || resource.data.isPublic == true;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /entries/{entryId} {
        allow read: if get(/databases/$(database)/documents/tierProjects/$(projectId)).data.isPublic == true
          || (request.auth != null
            && get(/databases/$(database)/documents/tierProjects/$(projectId)).data.ownerUid == request.auth.uid);
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/tierProjects/$(projectId)).data.ownerUid == request.auth.uid;
      }
    }

    match /huntingSpots/{spotId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if true;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /huntSessions/{sessionId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if true;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /bossCooldowns/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /activeImbuements/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /bestiaryProgress/{docId} {
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow write: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
    }

    match /characters/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
